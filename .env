OLLAMA_URL=http://localhost:11434
MODEL_ID=gpt-oss:20b
SERVER_PORT=8080
UI_ORIGIN=http://localhost:3000
ALLOW_TOOLS=true

# Database
DATABASE_PATH=data/conversations.db

# RAG
CHROMADB_PATH=data/chromadb
