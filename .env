# Rate limiting
MAX_REQUESTS_PER_MINUTE=60
MAX_REQUESTS_PER_CONVERSATION=10

# Tool configuration
MAX_WEB_PAGES_PER_TURN=5
MAX_HTML_SIZE_MB=2
WEB_TIMEOUT_SECONDS=10

# Generation settings
DEFAULT_TEMPERATURE=0.7
